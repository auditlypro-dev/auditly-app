import React, { useState } from "react";
import {
  Page,
  Card,
  Button,
  Layout,
  Text,
  Badge,
  Spinner
} from "@shopify/polaris";

export default function App() {
  const [loading, setLoading] = useState(false);
  const [result, setResult] = useState(null);

  const shop = new URLSearchParams(window.location.search).get("shop");

  async function runScan() {
    setLoading(true);

    try {
      const res = await fetch("/api/scan", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({ shop })
      });

      const data = await res.json();
      setResult(data);
    } catch (err) {
      console.error(err);
    }

    setLoading(false);
  }

  return (
    <Page title="Auditly Pro Dashboard">
      <Layout>
        <Layout.Section>

          <Card sectioned>
            <Text variant="headingLg">Compliance Overview</Text>
            <Text>Scan your Shopify store for compliance issues.</Text>

            <div style={{ marginTop: 20 }}>
              <Button primary onClick={runScan}>
                Run Compliance Scan
              </Button>
            </div>

            {loading && (
              <div style={{ marginTop: 20 }}>
                <Spinner size="large" />
              </div>
            )}
          </Card>

        </Layout.Section>

        {result && (
          <>
            <Layout.Section oneHalf>
              <Card sectioned>
                <Text variant="headingMd">Score</Text>
                <Badge size="large">{result.score}/100</Badge>
              </Card>
            </Layout.Section>

            <Layout.Section oneHalf>
              <Card sectioned>
                <Text variant="headingMd">Issues</Text>

                {result.issues.map((i, idx) => (
                  <p key={idx}>⚠️ {i}</p>
                ))}
              </Card>
            </Layout.Section>

            <Layout.Section>
              <Card sectioned>
                <Text variant="headingMd">Recommendations</Text>

                {result.recommendations.map((r, idx) => (
                  <p key={idx}>💡 {r}</p>
                ))}
              </Card>
            </Layout.Section>
          </>
        )}

      </Layout>
    </Page>
  );
}
